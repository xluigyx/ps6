# ─── Credenciales para desplegar/verificar en Sepolia ───────────
# Copia este archivo como hardhat/.env y completa los valores.
# NO se commitea (lo cubre el .gitignore raíz con el patrón ".env").

# RPC de Sepolia (Alchemy, Infura, etc.)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY

# Clave privada de una wallet DESECHABLE (solo para esta práctica). Con o sin 0x.
PRIVATE_KEY=tu_private_key_aqui

# API key de Etherscan (V2, una sola key multichain)
ETHERSCAN_API_KEY=tu_etherscan_api_key
